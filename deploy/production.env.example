# Copy to deploy/production.env on the server and fill real values there.
# Do not commit deploy/production.env.

STANDARD_OPS_ENV=production
STANDARD_OPS_HTTP_PORT=80
STANDARD_OPS_ALLOWED_ORIGINS=https://your-domain.example

STANDARD_OPS_POSTGRES_DB=wanfa_ops
STANDARD_OPS_POSTGRES_USER=wanfa_ops
STANDARD_OPS_POSTGRES_PASSWORD=replace-with-long-random-password

STANDARD_OPS_DEV_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

OUTBOX_EXTERNAL_WRITE_ENABLED=false
TRUSTED_INBOUND_WORKER_ENABLED=false
TRUSTED_INBOUND_WORKER_TENANT_SLUG=
TRUSTED_INBOUND_WORKER_USER_EMAIL=
# 微信客服灰度验收通过后，将 OUTBOX_EXTERNAL_WRITE_ENABLED 改为 true。
# 回调同步接口必须在平台超时前返回，建议保持 3.5 秒。
WECHAT_KF_HTTP_TIMEOUT_SECONDS=3.5

MODEL_BUDGET_GUARD_ENABLED=true
MODEL_BUDGET_SINGLE_CALL_LIMIT_CNY=0.20
MODEL_BUDGET_DAILY_LIMIT_CNY=20
MODEL_BUDGET_MONTHLY_LIMIT_CNY=300
MODEL_BUDGET_PRICING_SOURCE=production_operator_estimate

KNOWLEDGE_VECTOR_STORE=postgres_pgvector_store_v1
KNOWLEDGE_EMBEDDING_PROVIDER=auto
KNOWLEDGE_RERANKER=siliconflow_reranker_v1

BAILIAN_API_KEY=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
