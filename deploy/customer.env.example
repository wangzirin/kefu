# Customer local pilot package template.
# Copy to deploy/customer.env on the customer's machine and fill secrets locally.

STANDARD_OPS_ENV=pilot
STANDARD_OPS_DEV_BOOTSTRAP_ENABLED=false
STANDARD_OPS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

STANDARD_OPS_POSTGRES_DB=wanfa_ops
STANDARD_OPS_POSTGRES_USER=wanfa_ops
STANDARD_OPS_POSTGRES_PASSWORD=replace-with-local-random-password
STANDARD_OPS_POSTGRES_PORT=5432
STANDARD_OPS_REDIS_PORT=6379
STANDARD_OPS_BACKEND_PORT=18080
STANDARD_OPS_FRONTEND_PORT=5173

DATABASE_URL=postgresql+psycopg://wanfa_ops:replace-with-local-random-password@postgres:5432/wanfa_ops
REDIS_URL=redis://redis:6379/0
KNOWLEDGE_VECTOR_STORE=postgres_pgvector_store_v1

ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

OUTBOX_EXTERNAL_WRITE_ENABLED=false
TRUSTED_INBOUND_WORKER_ENABLED=false

MODEL_BUDGET_GUARD_ENABLED=true
MODEL_BUDGET_SINGLE_CALL_LIMIT_CNY=0.20
MODEL_BUDGET_DAILY_LIMIT_CNY=20
MODEL_BUDGET_MONTHLY_LIMIT_CNY=300
MODEL_BUDGET_PRICING_SOURCE=local_operator_estimate_customer_package_v1

BAILIAN_API_KEY=
DEEPSEEK_API_KEY=
