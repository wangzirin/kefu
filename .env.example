STANDARD_OPS_ENV=development
STANDARD_OPS_APP_NAME=Wanfa Customer Service Standard Ops
STANDARD_OPS_API_HOST=0.0.0.0
STANDARD_OPS_API_PORT=8080
STANDARD_OPS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_PROXY_TARGET=http://127.0.0.1:8081
# Development only. Keep false or unset in pilot/staging/production.
STANDARD_OPS_DEV_BOOTSTRAP_ENABLED=true

# For pilot deployment, replace database and Redis passwords in the customer environment.
# Do not store real production secrets in this template or in customer-facing documents.
DATABASE_URL=postgresql+psycopg://wanfa_ops:wanfa_ops_password@postgres:5432/wanfa_ops
REDIS_URL=redis://redis:6379/0

ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-production

# Model provider keys are intentionally blank. Real provider smoke requires explicit approval
# and a limited command such as --allow-external-call --limit 5.
BAILIAN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# For production smoke, prefer the current workspace endpoint:
# https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
BAILIAN_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_FAST_MODEL=qwen3.6-flash
BAILIAN_STANDARD_MODEL=qwen3.7-plus
BAILIAN_PREMIUM_MODEL=qwen3.7-max
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-flash
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
SILICONFLOW_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
SILICONFLOW_LLM_MODEL=Qwen/Qwen3.5-4B
MODEL_HTTP_TIMEOUT_SECONDS=20
# Model budget gate. 0 means "track but do not cap" for that limit.
# Prices are local operator estimates for routing/budget guard only, not provider bills.
MODEL_BUDGET_GUARD_ENABLED=true
MODEL_BUDGET_DAILY_LIMIT_CNY=0
MODEL_BUDGET_MONTHLY_LIMIT_CNY=0
MODEL_BUDGET_SINGLE_CALL_LIMIT_CNY=0
MODEL_BUDGET_COST_CURRENCY=CNY
MODEL_BUDGET_PRICING_SOURCE=operator_config_default_estimate_not_provider_bill
MODEL_BUDGET_PRICE_TABLE_VERSION=local-estimate-2026-07
MODEL_PRICE_BAILIAN_FAST_PER_1K_UNITS=0.001
MODEL_PRICE_BAILIAN_STANDARD_PER_1K_UNITS=0.004
MODEL_PRICE_BAILIAN_PREMIUM_PER_1K_UNITS=0.02
MODEL_PRICE_DEEPSEEK_PER_1K_UNITS=0.004
MODEL_PRICE_DETERMINISTIC_PER_1K_UNITS=0

KNOWLEDGE_EMBEDDING_PROVIDER=deterministic_local
KNOWLEDGE_EMBEDDING_API_BASE=
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_MODEL=deterministic-token-vector-v1
KNOWLEDGE_EMBEDDING_DIMENSIONS=64
# Open-source local embedding option for production-like RAG testing.
# Install backend optional dependency first: pip install -e "backend[embedding]"
# KNOWLEDGE_EMBEDDING_PROVIDER=local_bge_m3
# KNOWLEDGE_EMBEDDING_MODEL=BAAI/bge-m3
# KNOWLEDGE_EMBEDDING_DIMENSIONS=1024
# SiliconFlow API embedding option; one SILICONFLOW_API_KEY also covers rerank and chat.
# KNOWLEDGE_EMBEDDING_PROVIDER=siliconflow
# KNOWLEDGE_RERANKER=siliconflow_reranker_v1
# Used only for cost estimates in provider smoke/observability records; keep 0 until pricing is verified.
KNOWLEDGE_EMBEDDING_PRICE_PER_1K_TOKENS=0
KNOWLEDGE_EMBEDDING_COST_CURRENCY=CNY
KNOWLEDGE_VECTOR_STORE=postgres_pgvector_store_v1
# Development fallback only; production/local customer PostgreSQL runtime should use pgvector.
# KNOWLEDGE_VECTOR_STORE=sqlite_json_vector_store
KNOWLEDGE_RERANKER=siliconflow_reranker_v1
KNOWLEDGE_RERANKER=lexical_overlap_reranker_v1

# Pilot default: AI drafts can enter human review, but real external send remains off.
OUTBOX_WORKER_BATCH_SIZE=20
OUTBOX_WORKER_RATE_LIMIT_PER_MINUTE=60
OUTBOX_WORKER_MAX_ATTEMPTS=3
OUTBOX_EXTERNAL_WRITE_ENABLED=false

# Trusted inbound worker deployment profile. Keep disabled and tenant/user blank in templates.
# Enable only after the tenant, worker user and channel sandbox have been created.
TRUSTED_INBOUND_WORKER_ENABLED=false
TRUSTED_INBOUND_WORKER_TENANT_SLUG=
TRUSTED_INBOUND_WORKER_USER_EMAIL=
TRUSTED_INBOUND_WORKER_ID=trusted-inbound-worker-1
TRUSTED_INBOUND_WORKER_SLEEP_SECONDS=5
TRUSTED_INBOUND_WORKER_BATCH_SIZE=20
TRUSTED_INBOUND_WORKER_RATE_LIMIT_PER_MINUTE=60
TRUSTED_INBOUND_WORKER_LEASE_SECONDS=60
TRUSTED_INBOUND_WORKER_HEARTBEAT_STALE_AFTER_SECONDS=180

# Official channel secrets stay blank until the customer provides an approved test account
# or official platform authorization. Personal-account hook, group-control, and simulated-click
# paths are not part of the formal delivery plan.
WECOM_CORP_ID=
WECOM_KF_SECRET=
WECOM_KF_OPEN_KFID=
# Connector config should store only this public reference, not the real token/key:
# {"credential_ref":"env:WECOM_KF"}
WECOM_KF_CALLBACK_TOKEN=
WECOM_KF_ENCODING_AES_KEY=
WECOM_KF_RECEIVER_ID=
